import { defineField } from "sanity";

export const {{camelCase name}} = defineField({
  type: "object",
  name: "{{camelCase name}}",
  title: "{{titleCase (removeSectionSuffix name)}}",
  icon: () => <>❓</>,
  fields: [
    defineField({
      name: "title",
      type: "string",
    }),
  ],
  preview: {
    select: {
      title: "title",
    },
    prepare({ title }) {
      return {
        title,
        subtitle: "{{titleCase (removeSectionSuffix name)}}",
      };
    },
  },
});
