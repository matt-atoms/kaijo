{
  "name": "the-content-architecture-next-js",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.6.2"
  },
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 16.4",
    "ios_saf >= 16.4",
    "not dead"
  ],
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  },
  "scripts": {
    "clear": "rm -rf .next && rm -rf node_modules/.cache",
    "plop": "plop",
    "check.types": "tsc --noEmit -p tsconfig.json",
    "check.biome": "biome lint --diagnostic-level=error --no-errors-on-unmatched --files-ignore-unknown=true",
    "check": "concurrently npm:check.*",
    "test": "node --import=tsx --test \"scripts/**/*.test.ts\" \"features/**/*.test.ts\" \"sanity/**/*.test.ts\"",
    "format": "biome check --write --unsafe",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "sanity:typegen": "dotenvx run -- sh -c \"sanity schema extract --path='sanity-schema.json' && sanity typegen generate && sed -i.bak 's/| null/| undefined/g; s/null |/undefined |/g; s/{} |//g; s/| {}//g' sanity/types.ts && rm sanity/types.ts.bak\"",
    "sanity:cli": "dotenvx run -- sanity",
    "sanity:dataset-export": "dotenvx run -- node --import=tsx scripts/sanity-dataset/export.ts",
    "sanity:dataset-import": "dotenvx run -- node --import=tsx scripts/sanity-dataset/import.ts",
    "sanity:dataset-migrate": "dotenvx run -- node --import=tsx scripts/sanity-dataset/migrate.ts",
    "sanity:project-setup": "dotenvx run --ignore=MISSING_ENV_FILE -- node --import=tsx scripts/sanity-project-setup/setup.ts"
  },
  "dependencies": {
    "@activetheory/split-text": "1.1.2",
    "@dotenvx/dotenvx": "2.11.1",
    "@lottiefiles/dotlottie-react": "0.19.9",
    "@mantine/hooks": "9.4.1",
    "@mux/mux-player-react": "3.13.0",
    "@radix-ui/react-compose-refs": "1.1.3",
    "@rive-app/canvas-advanced-single": "2.38.5",
    "@rive-app/react-canvas": "4.29.5",
    "@sanity/vision": "6.5.0",
    "@t3-oss/env-nextjs": "0.13.11",
    "@tailwindcss/postcss": "4.3.2",
    "babel-plugin-react-compiler": "1.0.0",
    "change-case": "5.4.4",
    "cva": "1.0.0-beta.4",
    "geist": "1.7.2",
    "lenis": "1.3.25",
    "motion": "12.42.2",
    "next": "16.2.10",
    "next-sanity": "13.1.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "6.17.2",
    "sanity": "6.5.0",
    "sanity-plugin-media": "6.0.2",
    "sanity-plugin-mux-input": "5.0.3",
    "schema-dts": "2.0.0",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@sanity/cli": "^7.9.0",
    "@svgr/webpack": "8.1.0",
    "@types/negotiator": "0.6.4",
    "@types/node": "26.1.1",
    "@types/prompts": "2.4.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "commander": "15.0.0",
    "concurrently": "10.0.3",
    "lefthook": "2.1.10",
    "lint-staged": "17.0.8",
    "ora": "9.4.1",
    "plop": "4.0.5",
    "postcss": "8.5.19",
    "prompts": "2.4.2",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1",
    "typescript": "6.0.3"
  }
}
